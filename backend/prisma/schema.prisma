generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  user_id       Int            @id @default(autoincrement())
  login_id      String         @db.VarChar(50)
  password      String         @db.VarChar(255)
  name          String         @db.VarChar(50)
  major_id      Int
  grade         Int
  student_id    String         @db.VarChar(20)
  email         String         @db.VarChar(100)
  status        String         @default("ACTIVE") @db.VarChar(20)
  created_at    DateTime       @default(now()) @db.DateTime(0)
  is_push_noti  Boolean        @default(true)
  is_email_noti Boolean        @default(true)
  is_sms_noti   Boolean        @default(true)
  ACCESS_LOGS   ACCESS_LOGS[]
  carts         Carts[]
  INQUIRIES     INQUIRIES[]
  preferences   Preferences[]
  taken_courses TakenCourses[]
  timetables    Timetables[]
  majors        Majors         @relation(fields: [major_id], references: [major_id], onDelete: NoAction, onUpdate: NoAction, map: "USERS_ibfk_1")

  @@index([major_id], map: "major_id")
  @@map("USERS")
}

model Majors {
  major_id        Int               @id @default(autoincrement())
  college_name    String            @db.VarChar(50)
  major_name      String            @db.VarChar(50)
  courses         Courses[]
  GRADUATION_REQS GRADUATION_REQS[]
  users           Users[]

  @@map("MAJORS")
}

model Courses {
  course_id         Int                @id @default(autoincrement())
  course_code       String             @db.VarChar(50)
  course_name       String             @db.VarChar(100)
  organization      String?            @db.VarChar(500)
  major_id          Int
  classification    String             @db.VarChar(50)
  credits           Int
  professor         String?            @db.VarChar(50)
  capacity          Int                @default(0)
  cart_count        Int                @default(0)
  rating            Float              @default(0) @db.Float
  carts             Carts[]
  majors            Majors             @relation(fields: [major_id], references: [major_id], onDelete: NoAction, onUpdate: NoAction, map: "COURSES_ibfk_1")
  course_schedules  CourseSchedules[]
  timetable_courses TimetableCourses[]

  @@index([major_id], map: "major_id")
  @@map("COURSES")
}

model CourseSchedules {
  schedule_id  Int        @id @default(autoincrement())
  course_id    Int
  day_of_week  String     @db.VarChar(10)
  start_period Int
  end_period   Int
  building_id  Int?
  room_name    String?    @db.VarChar(50)
  courses      Courses    @relation(fields: [course_id], references: [course_id], onDelete: NoAction, onUpdate: NoAction, map: "COURSE_SCHEDULES_ibfk_1")
  buildings    Buildings? @relation(fields: [building_id], references: [building_id], onDelete: NoAction, onUpdate: NoAction, map: "COURSE_SCHEDULES_ibfk_2")

  @@index([building_id], map: "building_id")
  @@index([course_id], map: "course_id")
  @@map("COURSE_SCHEDULES")
}

model Buildings {
  building_id      Int               @id @default(autoincrement())
  building_name    String            @db.VarChar(50)
  course_schedules CourseSchedules[]
  from_distances   Distances[]       @relation("FromBuilding")
  to_distances     Distances[]       @relation("ToBuilding")

  @@map("BUILDINGS")
}

model Distances {
  distance_id      Int       @id @default(autoincrement())
  from_building_id Int
  to_building_id   Int
  time_minutes     Int
  is_uphill        Boolean   @default(false)
  from_building    Buildings @relation("FromBuilding", fields: [from_building_id], references: [building_id], onDelete: NoAction, onUpdate: NoAction, map: "DISTANCES_ibfk_1")
  to_building      Buildings @relation("ToBuilding", fields: [to_building_id], references: [building_id], onDelete: NoAction, onUpdate: NoAction, map: "DISTANCES_ibfk_2")

  @@index([from_building_id], map: "from_building_id")
  @@index([to_building_id], map: "to_building_id")
  @@map("DISTANCES")
}

model Carts {
  user_id    Int
  course_id  Int
  created_at DateTime @default(now()) @db.DateTime(0)
  users      Users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "CARTS_ibfk_1")
  courses    Courses  @relation(fields: [course_id], references: [course_id], onDelete: NoAction, onUpdate: NoAction, map: "CARTS_ibfk_2")

  @@id([user_id, course_id])
  @@index([course_id], map: "course_id")
  @@map("CARTS")
}

model Preferences {
  pref_id             Int     @id @default(autoincrement())
  user_id             Int
  preferred_time      String  @default("ANY") @db.VarChar(20)
  free_days           String? @db.VarChar(20)
  credit_intensity    String  @default("NORMAL") @db.VarChar(20)
  minimize_gaps       Boolean @default(false)
  prioritize_required Boolean @default(false)
  max_classes_per_day Int?
  avoid_uphill        Boolean @default(false)
  prefer_online       Boolean @default(false)
  users               Users   @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "PREFERENCES_ibfk_1")

  @@index([user_id], map: "user_id")
  @@map("PREFERENCES")
}

model Timetables {
  timetable_id       Int                @id @default(autoincrement())
  user_id            Int
  plan_type          String             @db.VarChar(10)
  is_selected        Boolean            @default(false)
  ai_comment         String?            @db.Text
  optimization_score Int                @default(0)
  characteristics    String?            @db.VarChar(100)
  created_at         DateTime           @default(now()) @db.DateTime(0)
  users              Users              @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "TIMETABLES_ibfk_1")
  timetable_courses  TimetableCourses[]

  @@index([user_id], map: "user_id")
  @@map("TIMETABLES")
}

model TimetableCourses {
  map_id       Int        @id @default(autoincrement())
  timetable_id Int
  course_id    Int
  timetables   Timetables @relation(fields: [timetable_id], references: [timetable_id], onDelete: NoAction, onUpdate: NoAction, map: "TIMETABLE_COURSES_ibfk_1")
  courses      Courses    @relation(fields: [course_id], references: [course_id], onDelete: NoAction, onUpdate: NoAction, map: "TIMETABLE_COURSES_ibfk_2")

  @@index([course_id], map: "course_id")
  @@index([timetable_id], map: "timetable_id")
  @@map("TIMETABLE_COURSES")
}

model TakenCourses {
  history_id     Int      @id @default(autoincrement())
  user_id        Int
  course_code    String   @db.VarChar(50)
  course_name    String   @db.VarChar(100)
  classification String   @db.VarChar(50)
  credits        Int
  created_at     DateTime @default(now()) @db.DateTime(0)
  users          Users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "TAKEN_COURSES_ibfk_1")

  @@index([user_id], map: "user_id")
  @@map("TAKEN_COURSES")
}

model Admins {
  admin_id           Int                  @id @default(autoincrement())
  login_id           String               @db.VarChar(50)
  password           String               @db.VarChar(255)
  name               String               @db.VarChar(50)
  email              String               @db.VarChar(100)
  role               String               @db.VarChar(20)
  AI_ADMIN_VARIABLES AI_ADMIN_VARIABLES[]
  INQUIRIES          INQUIRIES[]
  notices            Notices[]
  requested_configs  SystemConfigs[]      @relation("ConfigRequester")

  @@map("ADMINS")
}

model Notices {
  notice_id      Int      @id @default(autoincrement())
  admin_id       Int
  title          String   @db.VarChar(200)
  content        String   @db.Text
  created_at     DateTime @default(now()) @db.DateTime(0)
  attachment_url String?  @db.VarChar(255)
  admins         Admins   @relation(fields: [admin_id], references: [admin_id], onDelete: NoAction, onUpdate: NoAction, map: "NOTICES_ibfk_1")

  @@index([admin_id], map: "admin_id")
  @@map("NOTICES")
}

model SystemConfigs {
  config_id       Int      @id @default(autoincrement())
  config_key      String   @db.VarChar(100)
  config_value    String   @db.Text
  config_type     String   @db.VarChar(50)
  approval_status String   @default("PENDING") @db.VarChar(20)
  requested_by    Int
  updated_at      DateTime @default(now()) @updatedAt @db.DateTime(0)
  requester       Admins   @relation("ConfigRequester", fields: [requested_by], references: [admin_id], onDelete: NoAction, onUpdate: NoAction, map: "SYSTEM_CONFIGS_ibfk_1")

  @@index([requested_by], map: "requested_by")
  @@map("SYSTEM_CONFIGS")
}

model AiPromptTemplates {
  template_id        Int                  @id @default(autoincrement())
  template_name      String               @db.VarChar(100)
  fixed_prompt       String               @db.Text
  description        String?              @db.VarChar(255)
  version            Int                  @default(1)
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.DateTime(0)
  updated_at         DateTime             @default(now()) @updatedAt @db.DateTime(0)
  AI_ADMIN_VARIABLES AI_ADMIN_VARIABLES[]

  @@map("AI_PROMPT_TEMPLATES")
}

model ErrorLogs {
  log_id        Int      @id @default(autoincrement())
  error_type    String   @db.VarChar(50)
  error_message String   @db.Text
  created_at    DateTime @default(now()) @db.DateTime(0)

  @@map("ERROR_LOGS")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ACCESS_LOGS {
  log_id      Int      @id @default(autoincrement())
  user_id     Int?
  api_path    String   @db.VarChar(255)
  http_method String   @db.VarChar(10)
  created_at  DateTime @default(now()) @db.DateTime(0)
  USERS       Users?   @relation(fields: [user_id], references: [user_id], onUpdate: NoAction, map: "ACCESS_LOGS_ibfk_1")

  @@index([user_id], map: "user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model AI_ADMIN_VARIABLES {
  variable_id         Int               @id @default(autoincrement())
  template_id         Int
  admin_id            Int
  variable_key        String            @db.VarChar(100)
  variable_value      String            @db.Text
  description         String?           @db.VarChar(255)
  updated_at          DateTime          @default(now()) @db.DateTime(0)
  AI_PROMPT_TEMPLATES AiPromptTemplates @relation(fields: [template_id], references: [template_id], onDelete: NoAction, onUpdate: NoAction, map: "AI_ADMIN_VARIABLES_ibfk_1")
  ADMINS              Admins            @relation(fields: [admin_id], references: [admin_id], onDelete: NoAction, onUpdate: NoAction, map: "AI_ADMIN_VARIABLES_ibfk_2")

  @@index([admin_id], map: "admin_id")
  @@index([template_id], map: "template_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model GRADUATION_REQS {
  req_id              Int    @id @default(autoincrement())
  major_id            Int
  apply_year          String @db.VarChar(20)
  total_credits       Int
  basic_liberal       Int
  convergence_art     Int?
  convergence_society Int?
  convergence_nature  Int?
  convergence_world   Int?
  free_liberal        Int?
  area_liberal        Int?
  major_required      Int
  major_elective      Int
  MAJORS              Majors @relation(fields: [major_id], references: [major_id], onDelete: NoAction, onUpdate: NoAction, map: "GRADUATION_REQS_ibfk_1")

  @@index([major_id], map: "major_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model INQUIRIES {
  inquiry_id   Int       @id @default(autoincrement())
  user_id      Int
  inquiry_type String    @db.VarChar(50)
  title        String    @db.VarChar(200)
  content      String    @db.Text
  status       String    @default("PENDING") @db.VarChar(20)
  answer       String?   @db.Text
  answered_by  Int?
  created_at   DateTime  @default(now()) @db.DateTime(0)
  answered_at  DateTime? @db.DateTime(0)
  USERS        Users     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "INQUIRIES_ibfk_1")
  ADMINS       Admins?   @relation(fields: [answered_by], references: [admin_id], onDelete: NoAction, onUpdate: NoAction, map: "INQUIRIES_ibfk_2")

  @@index([answered_by], map: "answered_by")
  @@index([user_id], map: "user_id")
}
